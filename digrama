<mxfile host="app.diagrams.net">
  <diagram name="Facturación">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <!-- Inicio -->
        <mxCell id="i" value="Inicio" style="ellipse;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="300" y="40" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- Procesos -->
        <mxCell id="p1" value="Recibir datos de venta" style="rounded=0;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="260" y="150" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="p2" value="Verificar datos del cliente" style="rounded=0;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="260" y="260" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="p3" value="Generar factura" style="rounded=0;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="260" y="370" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- Decisión -->
        <mxCell id="d" value="¿Factura correcta?" style="rhombus;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="260" y="490" width="220" height="90" as="geometry"/>
        </mxCell>

        <!-- SI -->
        <mxCell id="p4" value="Enviar factura al cliente" style="rounded=0;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="260" y="620" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- NO -->
        <mxCell id="p5" value="Corregir errores" style="rounded=0;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="550" y="500" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- Fin -->
        <mxCell id="f" value="Fin" style="ellipse;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="300" y="740" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- Conexiones -->
        <mxCell edge="1" parent="1" source="i" target="p1" style="endArrow=block"/>
        <mxCell edge="1" parent="1" source="p1" target="p2" style="endArrow=block"/>
        <mxCell edge="1" parent="1" source="p2" target="p3" style="endArrow=block"/>
        <mxCell edge="1" parent="1" source="p3" target="d" style="endArrow=block"/>
        <mxCell edge="1" parent="1" source="d" target="p4" value="Sí" style="endArrow=block"/>
        <mxCell edge="1" parent="1" source="d" target="p5" value="No" style="endArrow=block"/>
        <mxCell edge="1" parent="1" source="p4" target="f" style="endArrow=block"/>
        <mxCell edge="1" parent="1" source="p5" target="p2" style="endArrow=block"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
